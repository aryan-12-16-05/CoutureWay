# Flask
FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=change-me-in-production
JWT_SECRET_KEY=change-me-too-in-production
JWT_EXPIRES_HOURS=72

# Database — SQLite for dev; swap to Postgres/MySQL with a single URI change, e.g.
# DATABASE_URL=postgresql+psycopg2://user:pass@localhost:5432/coutureway
DATABASE_URL=sqlite:///coutureway.db

# CORS — frontend origin(s), comma-separated
CORS_ORIGINS=http://localhost:8080,http://localhost:3000

# The email that is granted the admin role on signup (mirrors the old Supabase trigger)
ADMIN_EMAIL=alluriaryavardhanreddy@gmail.com
